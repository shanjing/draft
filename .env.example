# Ask (AI) LLM configuration. Set via: ./setup.sh → Configure Ask (AI) LLM?
# Values are stripped of surrounding quotes and whitespace (MarginCall-style).
#
# Embedding model (setup option 2): Hugging Face, Ollama, or Gemini; rebuild RAG index after changing
# DRAFT_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# DRAFT_EMBED_PROVIDER=ollama   # when using Ollama embed model
# DRAFT_EMBED_PROVIDER=gemini   # when using Gemini embedding (requires GEMINI_API_KEY)
# DRAFT_EMBED_MODEL=gemini-embedding-2-preview
#
# Hugging Face: offline-only (no network for models; use pre-downloaded or local)
HF_HUB_OFFLINE=1
#
# Provider: ollama | claude | gemini | openai
# DRAFT_LLM_PROVIDER=ollama
# DRAFT_LLM_MODEL=gemini-2.5-flash
#
# Local (Ollama) — OLLAMA_MODEL or LOCAL_AI_MODEL (ollama_chat/ prefix optional):
# OLLAMA_MODEL=qwen3:8b
#
# Cloud — set the key for your provider:
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENAI_API_KEY=sk-...
# CLOUD_AI_MODEL=gemini-2.5-flash
