# Ask (AI) LLM configuration. Set via: ./setup.sh → Configure Ask (AI) LLM?
# Values are stripped of surrounding quotes and whitespace (MarginCall-style).
#
# Provider: ollama | claude | gemini | openai
# DRAFT_LLM_PROVIDER=ollama
# DRAFT_LLM_MODEL=gemini-2.5-flash
#
# Local (Ollama) — OLLAMA_MODEL or LOCAL_AI_MODEL (ollama_chat/ prefix optional):
# OLLAMA_MODEL=qwen3:8b
#
# Cloud — set the key for your provider:
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENAI_API_KEY=sk-...
# CLOUD_AI_MODEL=gemini-2.5-flash
